# Node / Husky
node_modules/
.husky/_/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build artifacts
/bin/
frontend/build/
frontend/.svelte-kit/
frontend/dist/

# PWA / Playwright artifacts (regenerated)
frontend/dev-dist/
frontend/test-results/
frontend/playwright-report/

# PWA icons: the committed set lives in frontend/static/icons/ (generated from
# icon.svg by `pnpm icons:generate`). References use /icons/… so a clean build
# needs no generation; only the three web-root convention names (apple-touch-icon.png,
# favicon.png, ring-share-256.png) are mirrored to the root and committed. Nothing
# icon-related is generated into the static root anymore, so no ignore rule is needed.

# Embedded SvelteKit build output (regenerated by `make frontend-embed` /
# `make build`). The .gitkeep is committed so go:embed has a stable target
# pattern even on a fresh clone before the first build.
backend/internal/web/dist/*
!backend/internal/web/dist/.gitkeep

# Local env (never commit secrets)
.env
.env.local
.env.*.local

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Go
*.test
*.out
coverage.out
vendor/

# Docker / Caddy local data (volumes are external; this catches accidental local dirs)
caddy_data/
caddy_config/
pgdata/
