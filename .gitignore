# Node / Husky
node_modules/
.husky/_/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build artifacts
/bin/
frontend/build/
frontend/.svelte-kit/
frontend/dist/

# PWA / Playwright artifacts (regenerated)
frontend/dev-dist/
frontend/test-results/
frontend/playwright-report/

# Generated PWA assets. The single source is frontend/static/icon.svg; the
# production build regenerates the icon set + iOS splash images into
# frontend/build/, and the `pwa-assets-generator` CLI emits them into static/ —
# neither set is committed.
frontend/static/pwa-*.png
frontend/static/maskable-*.png
frontend/static/apple-touch-icon-*.png
frontend/static/apple-splash-*.png
frontend/static/favicon.ico

# Embedded SvelteKit build output (regenerated by `make frontend-embed` /
# `make build`). The .gitkeep is committed so go:embed has a stable target
# pattern even on a fresh clone before the first build.
backend/internal/web/dist/*
!backend/internal/web/dist/.gitkeep

# Local env (never commit secrets)
.env
.env.local
.env.*.local

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Go
*.test
*.out
coverage.out
vendor/

# Docker / Caddy local data (volumes are external; this catches accidental local dirs)
caddy_data/
caddy_config/
pgdata/
