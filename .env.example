# Ring — environment template. Copy to `.env` (never commit `.env`).
#
# Public FQDN the reverse proxy terminates TLS for.
# Dev default: ring.localtest.me (resolves to 127.0.0.1 via the public
# localtest.me service; Caddy issues an internal-CA cert).
# Prod: set to your real domain so Caddy can ACME a real cert.
RING_FQDN=ring.localtest.me

# Caddy upstream. Dev: host.docker.internal:8080 (Go binary on the host).
# Prod (auto-set by docker-compose.prod.yml): app:8080.
RING_UPSTREAM=host.docker.internal:8080

# Backend.
DATABASE_URL=postgres://ring:ring@localhost:5432/ring?sslmode=disable
LOG_LEVEL=info
LISTEN_ADDR=:8080
PUBLIC_URL=https://ring.localtest.me

# VAPID keypair for Web Push (generate with `make vapid-gen` in a later feature).
# Placeholders below are not valid keys.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
